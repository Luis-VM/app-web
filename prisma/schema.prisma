// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contacto {
  id        Int      @id @default(autoincrement())
  nombre    String
  empresa   String?
  email     String
  servicio  String?
  mensaje   String
  creadoEn  DateTime @default(now())
}